# Anthropic API key for the Claude chat loop — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Connecting to the MCP server ---
# Option A (deployment): point at a hosted Streamable HTTP server. If either of
# these is set, the client connects over HTTP and the stdio settings below are
# ignored. Use LOL_MCP_URL for the full endpoint, or LOL_MCP_HOST for just the
# hostname (the client builds https://<host>/mcp/ — handy for Render blueprints).
# LOL_MCP_URL=https://your-mcp-server.onrender.com/mcp/
# LOL_MCP_HOST=your-mcp-server.onrender.com
# Bearer token if the hosted server requires auth (matches its MCP_AUTH_TOKEN).
# LOL_MCP_TOKEN=
#
# Option B (local dev): spawn the Python server over stdio. Defaults assume the
# sibling ../lol-mcp-server directory and `uv` on PATH. On Windows, if `uv` isn't
# resolved by the child-process spawn, set LOL_MCP_COMMAND to the absolute
# uv.exe path (e.g. C:\Users\<you>\.local\bin\uv.exe).
LOL_MCP_COMMAND=uv
LOL_MCP_ARGS=run lol-mcp-server
# LOL_MCP_DIR=../lol-mcp-server
