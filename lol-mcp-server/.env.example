# Riot API key — get one at https://developer.riotgames.com/
# NOT needed for get_champion_info (Data Dragon is a public CDN).
# Required for the live-match / Spectator tools (next step).
RIOT_API_KEY=

# Routing for the live Riot API (only matters once we add live-match tools)
RIOT_REGIONAL_HOST=americas   # americas | europe | asia | sea
RIOT_PLATFORM_HOST=na1        # na1 | euw1 | eun1 | kr | ...

# Data Dragon static data
DDRAGON_VERSION=latest        # or pin e.g. 15.11.1 for reproducibility
DDRAGON_LOCALE=en_US

# Cache TTL for static Data Dragon payloads (seconds)
CACHE_TTL_SECONDS=3600

# Transport: stdio (local / MCP Inspector / local Next.js client) or http
# (hosted Streamable HTTP server for deployment).
MCP_TRANSPORT=stdio
# HTTP-only settings (ignored for stdio). PORT also falls back to the platform's
# injected $PORT on Render/Railway/etc.
HOST=0.0.0.0
PORT=8000
MCP_PATH=/mcp/
